#!/bin/bash

# Timestamp Converter Tool
# 支持 Unix 时间戳与日期时间的相互转换

set -e

VERSION="1.0.0"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

show_help() {
    cat << EOF
Timestamp Converter v${VERSION}

用法: ts <命令> [参数]

命令:
    now                      获取当前时间戳
    convert <timestamp>      时间戳转日期时间
    to-ts <date>             日期时间转时间戳
    format <timestamp> <fmt> 格式化输出
    add <timestamp> <delta>  时间加减 (如: 7days, 2hours, 30minutes)
    diff <ts1> <ts2>         计算两个时间戳的差
    parse <date>             解析任意日期格式
    help                     显示帮助信息
    version                  显示版本

示例:
    ts now
    ts convert 1704067200
    ts to-ts "2024-01-01 00:00:00"
    ts format 1704067200 "%Y年%m月%d日"
    ts add 1704067200 7days
    ts diff 1704067200 1704153600

EOF
}

# 获取当前时间戳
cmd_now() {
    local now=$(date +%s)
    local now_ms=$(date +%s%3N)
    echo -e "${GREEN}当前时间戳:${NC}"
    echo "  秒: ${now}"
    echo "  毫秒: ${now_ms}"
    echo -e "${GREEN}当前时间:${NC} $(date '+%Y-%m-%d %H:%M:%S %A')"
    echo -e "${GREEN}UTC:${NC} $(date -u '+%Y-%m-%d %H:%M:%S %Z')"
}

# 时间戳转日期时间
cmd_convert() {
    local timestamp=$1
    local utc_flag=$2
    
    if [[ -z "$timestamp" ]]; then
        echo -e "${RED}错误: 请提供时间戳${NC}"
        echo "用法: ts convert <timestamp>"
        exit 1
    fi
    
    # 处理毫秒时间戳 (13位)
    if [[ ${#timestamp} -eq 13 ]]; then
        timestamp=$((timestamp / 1000))
    fi
    
    # 验证时间戳格式
    if ! [[ "$timestamp" =~ ^-?[0-9]+$ ]]; then
        echo -e "${RED}错误: 无效的时间戳格式${NC}"
        exit 1
    fi
    
    echo -e "${GREEN}时间戳: ${NC}${timestamp}"
    
    if [[ "$utc_flag" == "--utc" || "$utc_flag" == "-u" ]]; then
        echo -e "${GREEN}UTC 时间:  ${NC}$(date -u -d "@${timestamp}" '+%Y-%m-%d %H:%M:%S')"
        echo -e "${GREEN}本地时间: ${NC}$(date -d "@${timestamp}" '+%Y-%m-%d %H:%M:%S')"
    else
        echo -e "${GREEN}日期时间: ${NC}$(date -d "@${timestamp}" '+%Y-%m-%d %H:%M:%S %A')"
        echo -e "${GREEN}UTC:      ${NC}$(date -u -d "@${timestamp}" '+%Y-%m-%d %H:%M:%S')"
    fi
    
    # 显示相对时间
    local diff=$(( $(date +%s) - timestamp ))
    if [[ $diff -gt 0 ]]; then
        echo -e "${BLUE}相对时间: ${NC}${diff} 秒前 ($(cmd_relative_time $diff))"
    elif [[ $diff -lt 0 ]]; then
        echo -e "${BLUE}相对时间: ${NC}$((-diff)) 秒后 ($(cmd_relative_time $((-diff))))"
    fi
}

# 计算相对时间
cmd_relative_time() {
    local seconds=$1
    if [[ $seconds -lt 60 ]]; then
        echo "${seconds}秒"
    elif [[ $seconds -lt 3600 ]]; then
        echo "$((seconds / 60))分钟"
    elif [[ $seconds -lt 86400 ]]; then
        echo "$((seconds / 3600))小时"
    elif [[ $seconds -lt 2592000 ]]; then
        echo "$((seconds / 86400))天"
    elif [[ $seconds -lt 31536000 ]]; then
        echo "$((seconds / 2592000))个月"
    else
        echo "$((seconds / 31536000))年"
    fi
}

# 日期时间转时间戳
cmd_to_ts() {
    local date_str=$1
    
    if [[ -z "$date_str" ]]; then
        echo -e "${RED}错误: 请提供日期时间${NC}"
        echo "用法: ts to-ts <date>"
        exit 1
    fi
    
    # 尝试多种日期格式
    local timestamp
    
    # 尝试直接解析
    timestamp=$(date -d "$date_str" +%s 2>/dev/null) || {
        # 尝试添加默认时间
        timestamp=$(date -d "${date_str} 00:00:00" +%s 2>/dev/null) || {
            echo -e "${RED}错误: 无法解析日期格式: ${date_str}${NC}"
            echo "支持的格式示例:"
            echo "  2024-01-01"
            echo "  2024/01/01"
            echo "  2024-01-01 12:30:45"
            echo "  Jan 1, 2024"
            echo "  1 Jan 2024"
            exit 1
        }
    }
    
    echo -e "${GREEN}日期时间: ${NC}${date_str}"
    echo -e "${GREEN}时间戳:   ${NC}${timestamp}"
    echo -e "${GREEN}毫秒:      ${NC}$(($timestamp * 1000))"
    
    # 显示转换后的日期
    echo -e "${GREEN}转换结果: ${NC}$(date -d "@${timestamp}" '+%Y-%m-%d %H:%M:%S %A')"
}

# 格式化输出
cmd_format() {
    local timestamp=$1
    local format=$2
    
    if [[ -z "$timestamp" || -z "$format" ]]; then
        echo -e "${RED}错误: 请提供时间戳和格式${NC}"
        echo "用法: ts format <timestamp> <format>"
        echo ""
        echo "格式说明:"
        echo "  %Y  年 (4位)"
        echo "  %m  月 (01-12)"
        echo "  %d  日 (01-31)"
        echo "  %H  时 (00-23)"
        echo "  %M  分 (00-59)"
        echo "  %S  秒 (00-59)"
        echo "  %A  星期几"
        echo ""
        echo "示例:"
        echo "  ts format 1704067200 '%Y年%m月%d日'"
        echo "  ts format 1704067200 '%Y-%m-%d %H:%M:%S'"
        exit 1
    fi
    
    # 处理毫秒时间戳
    if [[ ${#timestamp} -eq 13 ]]; then
        timestamp=$((timestamp / 1000))
    fi
    
    local result=$(date -d "@${timestamp}" "$format" 2>/dev/null) || {
        echo -e "${RED}错误: 无效的格式或时间戳${NC}"
        exit 1
    }
    
    echo -e "${GREEN}时间戳: ${NC}${timestamp}"
    echo -e "${GREEN}格式:   ${NC}${format}"
    echo -e "${GREEN}结果:   ${NC}${result}"
}

# 时间加减
cmd_add() {
    local timestamp=$1
    local delta=$2
    
    if [[ -z "$timestamp" || -z "$delta" ]]; then
        echo -e "${RED}错误: 请提供时间戳和时间增量${NC}"
        echo "用法: ts add <timestamp> <delta>"
        echo ""
        echo "增量格式:"
        echo "  7days     - 7天"
        echo "  2hours    - 2小时"
        echo "  30minutes - 30分钟"
        echo "  60seconds - 60秒"
        exit 1
    fi
    
    # 处理毫秒时间戳
    if [[ ${#timestamp} -eq 13 ]]; then
        timestamp=$((timestamp / 1000))
    fi
    
    # 解析增量
    local value=$(echo $delta | grep -oE '^[0-9]+')
    local unit=$(echo $delta | grep -oE '(days|hours|minutes|seconds|weeks|months|years)' | head -1)
    
    if [[ -z "$value" || -z "$unit" ]]; then
        echo -e "${RED}错误: 无效的增量格式${NC}"
        echo "支持的单位: days, hours, minutes, seconds, weeks, months, years"
        exit 1
    fi
    
    local seconds=0
    case $unit in
        seconds) seconds=$value ;;
        minutes) seconds=$((value * 60)) ;;
        hours)   seconds=$((value * 3600)) ;;
        days)    seconds=$((value * 86400)) ;;
        weeks)   seconds=$((value * 604800)) ;;
        months)  seconds=$((value * 2592000)) ;;
        years)   seconds=$((value * 31536000)) ;;
    esac
    
    local new_ts=$((timestamp + seconds))
    
    echo -e "${GREEN}原时间戳:  ${NC}${timestamp}"
    echo -e "${GREEN}增量:      ${NC}${delta} (${seconds}秒)"
    echo -e "${GREEN}新时间戳:  ${NC}${new_ts}"
    echo -e "${GREEN}新时间:    ${NC}$(date -d "@${new_ts}" '+%Y-%m-%d %H:%M:%S %A')"
}

# 计算时间差
cmd_diff() {
    local ts1=$1
    local ts2=$2
    
    if [[ -z "$ts1" || -z "$ts2" ]]; then
        echo -e "${RED}错误: 请提供两个时间戳${NC}"
        echo "用法: ts diff <timestamp1> <timestamp2>"
        exit 1
    fi
    
    # 处理毫秒时间戳
    if [[ ${#ts1} -eq 13 ]]; then
        ts1=$((ts1 / 1000))
    fi
    if [[ ${#ts2} -eq 13 ]]; then
        ts2=$((ts2 / 1000))
    fi
    
    local diff=$((ts2 - ts1))
    local abs_diff=${diff#-}
    
    echo -e "${GREEN}时间戳 1: ${NC}${ts1} ($(date -d "@${ts1}" '+%Y-%m-%d %H:%M:%S'))"
    echo -e "${GREEN}时间戳 2: ${NC}${ts2} ($(date -d "@${ts2}" '+%Y-%m-%d %H:%M:%S'))"
    echo -e "${GREEN}时间差:   ${NC}${diff} 秒"
    echo ""
    echo -e "${BLUE}详细:${NC}"
    
    local days=$((abs_diff / 86400))
    local hours=$(((abs_diff % 86400) / 3600))
    local minutes=$(((abs_diff % 3600) / 60))
    local seconds=$((abs_diff % 60))
    
    if [[ $days -gt 0 ]]; then
        echo "  ${days} 天"
    fi
    if [[ $hours -gt 0 ]]; then
        echo "  ${hours} 小时"
    fi
    if [[ $minutes -gt 0 ]]; then
        echo "  ${minutes} 分钟"
    fi
    if [[ $seconds -gt 0 || $abs_diff -eq 0 ]]; then
        echo "  ${seconds} 秒"
    fi
    
    # 转换为常见单位
    echo ""
    echo -e "${BLUE}换算:${NC}"
    echo "  ${abs_diff} 秒"
    echo "  $((abs_diff / 60)) 分钟"
    echo "  $((abs_diff / 3600)) 小时"
    echo "  $(awk "BEGIN {printf \"%.2f\", $abs_diff/86400}") 天"
}

# 解析任意日期格式
cmd_parse() {
    local date_str="$1"
    
    if [[ -z "$date_str" ]]; then
        echo -e "${RED}错误: 请提供日期字符串${NC}"
        echo "用法: ts parse <date>"
        exit 1
    fi
    
    echo -e "${GREEN}输入: ${NC}${date_str}"
    echo ""
    
    # 尝试多种格式
    local formats=(
        "%Y-%m-%d %H:%M:%S"
        "%Y-%m-%d"
        "%Y/%m/%d %H:%M:%S"
        "%Y/%m/%d"
        "%d-%m-%Y %H:%M:%S"
        "%d-%m-%Y"
        "%m/%d/%Y %H:%M:%S"
        "%m/%d/%Y"
        "%Y%m%d"
        "%Y%m%d%H%M%S"
    )
    
    local found=false
    for fmt in "${formats[@]}"; do
        local ts=$(date -d "$date_str" +%s 2>/dev/null)
        if [[ -n "$ts" ]]; then
            echo -e "${GREEN}解析成功!${NC}"
            echo -e "${GREEN}时间戳: ${NC}${ts}"
            echo -e "${GREEN}毫秒:   ${NC}$(($ts * 1000))"
            echo -e "${GREEN}日期:   ${NC}$(date -d "@${ts}" '+%Y-%m-%d %H:%M:%S %A')"
            found=true
            break
        fi
    done
    
    if [[ "$found" == "false" ]]; then
        echo -e "${RED}无法解析日期格式${NC}"
        echo "请尝试以下格式:"
        echo "  2024-01-01"
        echo "  2024/01/01"
        echo "  2024-01-01 12:30:45"
        echo "  Jan 1, 2024"
        echo "  1 Jan 2024"
    fi
}

# 主命令处理
case "$1" in
    help|--help|-h)
        show_help
        ;;
    version|--version|-v)
        echo "Timestamp Converter v${VERSION}"
        ;;
    now)
        cmd_now
        ;;
    convert)
        cmd_convert "$2" "$3"
        ;;
    to-ts|toTimestamp|tots)
        cmd_to_ts "$2"
        ;;
    format)
        cmd_format "$2" "$3"
        ;;
    add)
        cmd_add "$2" "$3"
        ;;
    diff)
        cmd_diff "$2" "$3"
        ;;
    parse)
        cmd_parse "$2"
        ;;
    "")
        show_help
        ;;
    *)
        echo -e "${RED}错误: 未知命令 '$1'${NC}"
        echo "运行 'ts help' 查看帮助"
        exit 1
        ;;
esac
