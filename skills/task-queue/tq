#!/bin/bash
# Task Queue Manager - Background job processing tool

set -e

CONFIG_DIR="${HOME}/.config/task-queue"
DATA_DIR="${HOME}/.local/share/task-queue"
QUEUES_DIR="${DATA_DIR}/queues"
JOBS_DIR="${DATA_DIR}/jobs"
SCHEDULE_DIR="${DATA_DIR}/schedules"
WORKERS_DIR="${DATA_DIR}/workers"
LOG_DIR="${DATA_DIR}/logs"

mkdir -p "$QUEUES_DIR" "$JOBS_DIR" "$SCHEDULE_DIR" "$WORKERS_DIR" "$LOG_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() { echo -e "${GREEN}[TQ]${NC} $1"; }
error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }

show_help() {
    cat << EOF
Task Queue Manager - Background job processing

Usage: tq <command> [options]

Commands:
    Queue Operations:
        enqueue <queue> <payload>        Add job to queue (JSON or text)
        enqueue-priority <queue> <payload> Add high priority job
        enqueue-delay <queue> <delay> <payload> Add delayed job (seconds)
        dequeue <queue>                   Get next job from queue
        list-queues                       List all queues
        queue-stats <queue>              Show queue statistics
        clear-queue <queue>              Clear all jobs in queue

    Job Operations:
        job-status <job-id>               Check job status
        job-retry <job-id>               Retry failed job
        job-cancel <job-id>              Cancel pending job
        job-list <queue>                  List jobs in queue

    Worker Operations:
        worker-start <queue> [--workers=N] Start workers (default: 1)
        worker-stop                       Stop all workers
        worker-status                     Show worker status
        worker-logs [worker-id]           Show worker logs

    Scheduled Jobs:
        schedule add <name> <cron> <job>  Add scheduled job
        schedule list                     List scheduled jobs
        schedule remove <name>            Remove scheduled job
        schedule enable <name>            Enable scheduled job
        schedule disable <name>           Disable scheduled job
        schedule run <name>               Run scheduled job now

    Utility:
        stats                             Overall statistics
        ping                              Health check
        help                              Show this help

Examples:
    tq enqueue emails '{"to":"user@example.com"}'
    tq worker-start emails --workers=3
    tq schedule add backup "0 2 * * *" '{"cmd":"backup"}'
    tq queue-stats emails

EOF
}

# Generate unique job ID
gen_job_id() {
    echo "job_$(date +%s)_$RANDOM"
}

# Generate worker ID
gen_worker_id() {
    echo "worker_$(date +%s)_$RANDOM"
}

# Get queue file path
queue_file() {
    echo "$QUEUES_DIR/$1.queue"
}

# Get job file path
job_file() {
    echo "$JOBS_DIR/$1.job"
}

# Enqueue a job
cmd_enqueue() {
    local queue="$1"
    local payload="$2"
    local priority="${3:-normal}"
    local delay="${4:-0}"
    
    if [[ -z "$queue" || -z "$payload" ]]; then
        error "Usage: enqueue <queue> <payload> [priority] [delay]"
        exit 1
    fi
    
    local job_id=$(gen_job_id)
    local timestamp=$(date +%s)
    local status="pending"
    
    if [[ "$delay" -gt 0 ]]; then
        local run_at=$((timestamp + delay))
        status="delayed"
    fi
    
    # Write job file
    cat > "$(job_file $job_id)" << EOF
JOB_ID=$job_id
QUEUE=$queue
PAYLOAD=$payload
PRIORITY=$priority
STATUS=$status
CREATED_AT=$timestamp
RUN_AT=${run_at:-$timestamp}
RETRIES=0
MAX_RETRIES=3
EOF
    
    # Add to queue (sorted by priority and timestamp)
    local queue_f=$(queue_file $queue)
    echo "$timestamp:$priority:$job_id" >> "$queue_f"
    
    # Sort queue by priority
    if [[ -f "$queue_f" ]]; then
        sort -t':' -k2,2 -k1,1n "$queue_f" -o "$queue_f" 2>/dev/null || true
    fi
    
    log "Job $job_id enqueued to $queue (priority: $priority, delay: ${delay}s)"
    echo "$job_id"
}

# Dequeue next job
cmd_dequeue() {
    local queue="$1"
    
    if [[ -z "$queue" ]]; then
        error "Usage: dequeue <queue>"
        exit 1
    fi
    
    local queue_f=$(queue_file $queue)
    
    if [[ ! -f "$queue_f" ]] || [[ ! -s "$queue_f" ]]; then
        echo "Queue $queue is empty"
        exit 0
    fi
    
    # Read first job
    local line=$(head -1 "$queue_f")
    local job_id=$(echo "$line" | cut -d':' -f3)
    local job_f=$(job_file $job_id)
    
    if [[ -f "$job_f" ]]; then
        # Update status
        sed -i 's/STATUS=.*/STATUS=processing/' "$job_f"
        sed -i "s/WORKER_ID=.*/WORKER_ID=self/" "$job_f" 2>/dev/null || true
        sed -i "s/STARTED_AT=.*/STARTED_AT=$(date +%s)/" "$job_f" 2>/dev/null || true
        
        # Remove from queue
        tail -n +2 "$queue_f" > "${queue_f}.tmp" && mv "${queue_f}.tmp" "$queue_f"
        
        # Output job
        cat "$job_f"
    else
        error "Job file not found: $job_id"
        exit 1
    fi
}

# Complete a job
cmd_complete() {
    local job_id="$1"
    local job_f=$(job_file $job_id)
    
    if [[ ! -f "$job_f" ]]; then
        error "Job not found: $job_id"
        exit 1
    fi
    
    sed -i 's/STATUS=.*/STATUS=completed/' "$job_f"
    sed -i "s/COMPLETED_AT=.*/COMPLETED_AT=$(date +%s)/" "$job_f"
    log "Job $job_id completed"
}

# Fail a job (with retry)
cmd_fail() {
    local job_id="$1"
    local job_f=$(job_file $job_id)
    
    if [[ ! -f "$job_f" ]]; then
        error "Job not found: $job_id"
        exit 1
    fi
    
    local retries=$(grep "^RETRIES=" "$job_f" | cut -d'=' -f2)
    local max_retries=$(grep "^MAX_RETRIES=" "$job_f" | cut -d'=' -f2)
    
    retries=$((retries + 1))
    
    if [[ "$retries" -lt "$max_retries" ]]; then
        # Re-queue for retry
        sed -i "s/RETRIES=.*/RETRIES=$retries/" "$job_f"
        sed -i 's/STATUS=.*/STATUS=pending/' "$job_f"
        
        local queue=$(grep "^QUEUE=" "$job_f" | cut -d'=' -f2)
        local queue_f=$(queue_file $queue)
        echo "$(date +%s):normal:$job_id" >> "$queue_f"
        
        log "Job $job_id failed, retry $retries/$max_retries"
    else
        sed -i 's/STATUS=.*/STATUS=failed/' "$job_f"
        error "Job $job_id failed after $max_retries retries"
    fi
}

# List all queues
cmd_list_queues() {
    echo -e "${BLUE}Queues:${NC}"
    
    if [[ ! -d "$QUEUES_DIR" ]] || [[ -z "$(ls -A "$QUEUES_DIR" 2>/dev/null)" ]]; then
        echo "  No queues found"
        return
    fi
    
    for f in "$QUEUES_DIR"/*.queue; do
        [[ -f "$f" ]] || continue
        local name=$(basename "$f" .queue)
        local count=$(wc -l < "$f")
        echo -e "  ${GREEN}$name${NC}: $count jobs"
    done
}

# Queue statistics
cmd_queue_stats() {
    local queue="$1"
    
    if [[ -z "$queue" ]]; then
        error "Usage: queue-stats <queue>"
        exit 1
    fi
    
    local queue_f=$(queue_file $queue)
    
    if [[ ! -f "$queue_f" ]]; then
        error "Queue not found: $queue"
        exit 1
    fi
    
    local total=$(wc -l < "$queue_f")
    local high=$(grep -c ":high:" "$queue_f" 2>/dev/null || echo 0)
    local normal=$(grep -c ":normal:" "$queue_f" 2>/dev/null || echo 0)
    local low=$(grep -c ":low:" "$queue_f" 2>/dev/null || echo 0)
    
    echo -e "${BLUE}Queue: $queue${NC}"
    echo "  Total jobs: $total"
    echo "  High priority: $high"
    echo "  Normal: $normal"
    echo "  Low: $low"
    
    # Job status breakdown
    local pending=0
    local processing=0
    local completed=0
    local failed=0
    
    for job_file in "$JOBS_DIR"/*.job; do
        [[ -f "$job_file" ]] || continue
        local q=$(grep "^QUEUE=" "$job_file" 2>/dev/null | cut -d'=' -f2)
        if [[ "$q" == "$queue" ]]; then
            local status=$(grep "^STATUS=" "$job_file" | cut -d'=' -f2)
            case "$status" in
                pending) pending=$((pending + 1)) ;;
                processing) processing=$((processing + 1)) ;;
                completed) completed=$((completed + 1)) ;;
                failed) failed=$((failed + 1)) ;;
            esac
        fi
    done
    
    echo -e "\n  ${GREEN}Completed: $completed${NC}"
    echo -e "  ${YELLOW}Processing: $processing${NC}"
    echo -e "  ${RED}Failed: $failed${NC}"
}

# List jobs in queue
cmd_job_list() {
    local queue="$1"
    
    if [[ -z "$queue" ]]; then
        error "Usage: job-list <queue>"
        exit 1
    fi
    
    echo -e "${BLUE}Jobs in $queue:${NC}"
    
    local found=0
    for job_file in "$JOBS_DIR"/*.job; do
        [[ -f "$job_file" ]] || continue
        local q=$(grep "^QUEUE=" "$job_file" 2>/dev/null | cut -d'=' -f2)
        if [[ "$q" == "$queue" ]]; then
            found=1
            local job_id=$(basename "$job_file" .job)
            local status=$(grep "^STATUS=" "$job_file" | cut -d'=' -f2)
            local priority=$(grep "^PRIORITY=" "$job_file" | cut -d'=' -f2)
            local created=$(grep "^CREATED_AT=" "$job_file" | cut -d'=' -f2)
            local created_str=$(date -d "@$created" 2>/dev/null || echo "$created")
            
            echo -e "  $job_id"
            echo -e "    Status: $status | Priority: $priority | Created: $created_str"
        fi
    done
    
    [[ $found -eq 0 ]] && echo "  No jobs found"
}

# Job status
cmd_job_status() {
    local job_id="$1"
    
    if [[ -z "$job_id" ]]; then
        error "Usage: job-status <job-id>"
        exit 1
    fi
    
    local job_f=$(job_file $job_id)
    
    if [[ ! -f "$job_f" ]]; then
        error "Job not found: $job_id"
        exit 1
    fi
    
    echo -e "${BLUE}Job: $job_id${NC}"
    cat "$job_f"
}

# Job retry
cmd_job_retry() {
    local job_id="$1"
    local job_f=$(job_file $job_id)
    
    if [[ ! -f "$job_f" ]]; then
        error "Job not found: $job_id"
        exit 1
    fi
    
    local queue=$(grep "^QUEUE=" "$job_f" | cut -d'=' -f2)
    local queue_f=$(queue_file $queue)
    
    # Reset job
    sed -i 's/STATUS=.*/STATUS=pending/' "$job_f"
    sed -i 's/RETRIES=.*/RETRIES=0/' "$job_f"
    
    # Re-queue
    echo "$(date +%s):normal:$job_id" >> "$queue_f"
    
    log "Job $job_id re-queued"
}

# Job cancel
cmd_job_cancel() {
    local job_id="$1"
    local job_f=$(job_file $job_id)
    
    if [[ ! -f "$job_f" ]]; then
        error "Job not found: $job_id"
        exit 1
    fi
    
    sed -i 's/STATUS=.*/STATUS=cancelled/' "$job_f"
    log "Job $job_id cancelled"
}

# Clear queue
cmd_clear_queue() {
    local queue="$1"
    local queue_f=$(queue_file $queue)
    
    if [[ ! -f "$queue_f" ]]; then
        error "Queue not found: $queue"
        exit 1
    fi
    
    > "$queue_f"
    log "Queue $queue cleared"
}

# Worker start
cmd_worker_start() {
    local queue="$1"
    local workers="${2:-1}"
    
    if [[ -z "$queue" ]]; then
        error "Usage: worker-start <queue> [--workers=N]"
        exit 1
    fi
    
    # Extract worker count
    workers=$(echo "$workers" | grep -o '[0-9]*' || echo 1)
    [[ -z "$workers" ]] && workers=1
    
    log "Starting $workers worker(s) for queue: $queue"
    
    for i in $(seq 1 $workers); do
        local worker_id=$(gen_worker_id)
        
        # Write worker info
        cat > "$WORKERS_DIR/$worker_id.info" << EOF
WORKER_ID=$worker_id
QUEUE=$queue
STARTED_AT=$(date +%s)
STATUS=running
EOF
        
        # Start worker in background
        (
            while true; do
                local job=$(tq dequeue "$queue" 2>/dev/null)
                
                if [[ -z "$job" ]] || [[ "$job" == *"is empty"* ]]; then
                    sleep 1
                    continue
                fi
                
                local job_id=$(echo "$job" | grep "^JOB_ID=" | cut -d'=' -f2)
                local payload=$(echo "$job" | grep "^PAYLOAD=" | cut -d'=' -f2-)
                
                echo "$(date): Processing $job_id" >> "$LOG_DIR/$worker_id.log"
                
                # Simulate job processing (in real implementation, execute the payload)
                # Here we just mark as completed for demo
                tq complete "$job_id" 2>/dev/null || true
                
                echo "$(date): Completed $job_id" >> "$LOG_DIR/$worker_id.log"
            done
        ) &
        
        echo "Worker $worker_id started (PID: $!)"
    done
    
    log "$workers worker(s) started"
}

# Worker stop
cmd_worker_stop() {
    # Kill all worker processes
    pkill -f "tq dequeue" 2>/dev/null || true
    
    # Update status
    for f in "$WORKERS_DIR"/*.info; do
        [[ -f "$f" ]] || continue
        sed -i 's/STATUS=.*/STATUS=stopped/' "$f"
    done
    
    log "All workers stopped"
}

# Worker status
cmd_worker_status() {
    echo -e "${BLUE}Workers:${NC}"
    
    if [[ ! -d "$WORKERS_DIR" ]] || [[ -z "$(ls -A "$WORKERS_DIR" 2>/dev/null)" ]]; then
        echo "  No workers"
        return
    fi
    
    for f in "$WORKERS_DIR"/*.info; do
        [[ -f "$f" ]] || continue
        local worker_id=$(basename "$f" .info)
        local queue=$(grep "^QUEUE=" "$f" | cut -d'=' -f2)
        local status=$(grep "^STATUS=" "$f" | cut -d'=' -f2)
        local started=$(grep "^STARTED_AT=" "$f" | cut -d'=' -f2)
        local started_str=$(date -d "@$started" 2>/dev/null || echo "$started")
        
        echo -e "  ${GREEN}$worker_id${NC}"
        echo -e "    Queue: $queue | Status: $status | Started: $started_str"
    done
}

# Worker logs
cmd_worker_logs() {
    local worker_id="$1"
    
    if [[ -n "$worker_id" ]]; then
        local log_file="$LOG_DIR/$worker_id.log"
        if [[ -f "$log_file" ]]; then
            tail -20 "$log_file"
        else
            error "No logs for worker: $worker_id"
        fi
    else
        echo -e "${BLUE}All worker logs:${NC}"
        for f in "$LOG_DIR"/*.log; do
            [[ -f "$f" ]] || continue
            echo -e "${GREEN}$(basename $f):${NC}"
            tail -5 "$f"
            echo ""
        done
    fi
}

# Schedule add
cmd_schedule_add() {
    local name="$1"
    local cron="$2"
    local job="$3"
    
    if [[ -z "$name" || -z "$cron" || -z "$job" ]]; then
        error "Usage: schedule add <name> <cron> <job>"
        exit 1
    fi
    
    cat > "$SCHEDULE_DIR/$name.schedule" << EOF
NAME=$name
CRON=$cron
JOB=$job
ENABLED=true
LAST_RUN=
NEXT_RUN=
EOF
    
    log "Scheduled job $name added (cron: $cron)"
}

# Schedule list
cmd_schedule_list() {
    echo -e "${BLUE}Scheduled Jobs:${NC}"
    
    if [[ ! -d "$SCHEDULE_DIR" ]] || [[ -z "$(ls -A "$SCHEDULE_DIR" 2>/dev/null)" ]]; then
        echo "  No scheduled jobs"
        return
    fi
    
    for f in "$SCHEDULE_DIR"/*.schedule; do
        [[ -f "$f" ]] || continue
        local name=$(basename "$f" .schedule)
        local cron=$(grep "^CRON=" "$f" | cut -d'=' -f2)
        local enabled=$(grep "^ENABLED=" "$f" | cut -d'=' -f2)
        
        echo -e "  ${GREEN}$name${NC}"
        echo "    Cron: $cron | Enabled: $enabled"
    done
}

# Schedule remove
cmd_schedule_remove() {
    local name="$1"
    local schedule_file="$SCHEDULE_DIR/$name.schedule"
    
    if [[ ! -f "$schedule_file" ]]; then
        error "Scheduled job not found: $name"
        exit 1
    fi
    
    rm "$schedule_file"
    log "Scheduled job $name removed"
}

# Schedule enable/disable
cmd_schedule_toggle() {
    local name="$1"
    local enabled="$2"
    local schedule_file="$SCHEDULE_DIR/$name.schedule"
    
    if [[ ! -f "$schedule_file" ]]; then
        error "Scheduled job not found: $name"
        exit 1
    fi
    
    sed -i "s/ENABLED=.*/ENABLED=$enabled/" "$schedule_file"
    log "Scheduled job $name $enabled"
}

# Stats
cmd_stats() {
    echo -e "${BLUE}Task Queue Statistics${NC}"
    
    # Count queues
    local queue_count=$(ls -1 "$QUEUES_DIR"/*.queue 2>/dev/null | wc -l)
    echo "  Queues: $queue_count"
    
    # Count jobs
    local job_count=$(ls -1 "$JOBS_DIR"/*.job 2>/dev/null | wc -l)
    echo "  Total jobs: $job_count"
    
    # Count workers
    local worker_count=$(ls -1 "$WORKERS_DIR"/*.info 2>/dev/null | wc -l)
    echo "  Workers: $worker_count"
    
    # Count schedules
    local schedule_count=$(ls -1 "$SCHEDULE_DIR"/*.schedule 2>/dev/null | wc -l)
    echo "  Scheduled jobs: $schedule_count"
}

# Ping
cmd_ping() {
    echo "pong"
}

# Main
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    help|--help|-h)
        show_help
        ;;
    enqueue)
        cmd_enqueue "$@"
        ;;
    enqueue-priority)
        cmd_enqueue "$1" "$2" "high"
        ;;
    enqueue-delay)
        cmd_enqueue "$1" "$3" "normal" "$2"
        ;;
    dequeue)
        cmd_dequeue "$@"
        ;;
    complete)
        cmd_complete "$@"
        ;;
    fail)
        cmd_fail "$@"
        ;;
    list-queues)
        cmd_list_queues
        ;;
    queue-stats)
        cmd_queue_stats "$@"
        ;;
    job-list)
        cmd_job_list "$@"
        ;;
    job-status)
        cmd_job_status "$@"
        ;;
    job-retry)
        cmd_job_retry "$@"
        ;;
    job-cancel)
        cmd_job_cancel "$@"
        ;;
    clear-queue)
        cmd_clear_queue "$@"
        ;;
    worker-start)
        cmd_worker_start "$@"
        ;;
    worker-stop)
        cmd_worker_stop
        ;;
    worker-status)
        cmd_worker_status
        ;;
    worker-logs)
        cmd_worker_logs "$@"
        ;;
    schedule)
        local subcmd="$1"
        case "$subcmd" in
            add) shift; cmd_schedule_add "$@" ;;
            list) cmd_schedule_list ;;
            remove) shift; cmd_schedule_remove "$@" ;;
            enable) shift; cmd_schedule_toggle "$@" "true" ;;
            disable) shift; cmd_schedule_toggle "$@" "false" ;;
            *) show_help ;;
        esac
        ;;
    stats)
        cmd_stats
        ;;
    ping)
        cmd_ping
        ;;
    *)
        error "Unknown command: $COMMAND"
        show_help
        exit 1
        ;;
esac
